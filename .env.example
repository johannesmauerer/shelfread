# Convex
CONVEX_DEPLOYMENT=             # your convex deployment URL

# Gemini (set in Convex dashboard, not here)
# GEMINI_API_KEY=              # Google Gemini API key

# Email Ingestion (Phase 3 - Mailgun or similar)
# SHELF_INGEST_URL=            # Convex HTTP action URL for /ingest
# SHELF_INGEST_KEY=            # Shared secret for ingest authentication
# ALLOWED_SENDERS=             # Comma-separated email addresses

# OPDS (generated during setup, stored in Convex)
# OPDS_SECRET_PATH=            # Auto-generated UUID
# OPDS_USERNAME=               # Set via dashboard
# OPDS_PASSWORD=               # Set via dashboard
